# Conexão com o Postgres do Supabase (use o pooler na porta 6543, transaction mode).
# Ex.: postgresql://postgres.<project_ref>:<senha>@aws-0-<regiao>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://usuario:senha@host:6543/postgres

# Caminho do CSV de entrada (camada bronze).
CSV_PATH=data/results.csv
